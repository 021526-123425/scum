

#!/usr/bin/env bash

elect_spark() {
  local pattern="$1"

  local all
  all=$(pgrep -f "$pattern") || return 0

  local spark
  spark=$(pgrep -fo "$pattern")

  echo "$all" \
    | grep -v "$spark" \
    | xargs -r kill -TERM

  echo "[✓] Spark elected for '$pattern' — duplicates terminated."
}

DAEMONS=(
  "1. Pain"
  "2. DontTrip"
  "inconverient" 
  "music"
  "push"
  "ZZ-Admin"
  "bags"
  "archatypes"
  "News"
  "Video" 
  "FreeAcid" 
  "FreeAcid2" 
  "FreeAcid3" 
  "FreeAcid4" 
  "FreeAcid5" 
  "Endermanch" 
  "Endermanch1" 
  "Endermanch2" 
  "Endermanch3" 
  "Endermanch4" 
  "Push" 
  "Push2" 
  "Push3" 
  "Push4" 
  "Push5" 
  "System7.1"

echo "⚡ Convening the Spark Council..."
echo

for daemon in "${DAEMONS[@]}"; do
  echo "→ Electing spark for: $daemon"
  elect_spark "$daemon"
  echo
done

echo 
"✨ All sparks elected. The Council stands in harmony."
